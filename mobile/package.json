{
  "name": "estiba-wms-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~57.0.6",
    "expo-build-properties": "~57.0.5",
    "expo-crypto": "~57.0.1",
    "expo-screen-orientation": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "expo-updates": "~57.0.7",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "start:tunnel": "expo start --tunnel",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "export:android": "expo export --platform android --output-dir dist",
    "eas:configure": "npx eas-cli@latest update:configure",
    "build:apk": "npx eas-cli@latest build -p android --profile apk-camaras",
    "update:production": "npx eas-cli@latest update --channel production --environment production"
  },
  "private": true
}
